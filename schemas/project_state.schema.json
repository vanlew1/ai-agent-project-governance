{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vanlew1.github.io/ai-agent-project-governance/schemas/project_state.schema.json",
  "title": "Governance Project State",
  "description": "Durable project facts independent of a single task conversation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "project_mode", "architecture_status", "implementation_plan_status", "repository_root", "adapter", "high_risk_paths", "default_forbidden_operations"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "project_mode": {"enum": ["DISCOVERY", "ADAPTATION", "EXECUTION"]},
    "architecture_status": {"enum": ["draft", "confirmed", "superseded"]},
    "implementation_plan_status": {"enum": ["draft", "ready_for_confirmation", "confirmed", "superseded"]},
    "repository_root": {"type": "string", "minLength": 1},
    "adapter": {"type": "string", "minLength": 1},
    "high_risk_paths": {"type": "array", "items": {"type": "string"}},
    "default_forbidden_operations": {"type": "array", "items": {"type": "string"}},
    "auxiliary_adapters": {"type": "array", "items": {"type": "string"}},
    "adapter_detection_status": {"enum": ["DETECTED", "MIXED", "FALLBACK", "ERROR"]},
    "status": {"enum": ["UNSPECIFIED", "INSTALLED_NOT_ACTIVATED", "ACTIVATED_NOT_PREFLIGHTED"]},
    "activated": {"type": "boolean"},
    "activation_status": {"enum": ["NOT_ACTIVATED", "ACTIVATED_NOT_PREFLIGHTED"]},
    "activation_approval_digest": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "activation_receipt_digest": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "preflight_executed": {"type": "boolean"},
    "tests_executed": {"type": "boolean"},
    "verification_completed": {"type": "boolean"},
    "closure_completed": {"type": "boolean"},
    "production_ready": {"type": "boolean"},
    "release_authorized": {"type": "boolean"},
    "network_authorized": {"type": "boolean"},
    "git_write_authorized": {"type": "boolean"}
    ,"lifecycle_stage": {"enum": ["UNSPECIFIED", "INSTALLED_NOT_ACTIVATED", "ACTIVATED_NOT_PREFLIGHTED", "PREFLIGHT_PASSED", "GUARDED", "TEST_PLANNED", "TEST_EXECUTED", "VERIFIED", "CLOSED"]}
    ,"lifecycle_evidence": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["stage", "evidence_type", "evidence_digest", "previous_state_digest"], "properties": {"stage": {"type": "string"}, "evidence_type": {"type": "string"}, "evidence_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "evidence_file_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "evidence_file": {"type": "string", "minLength": 1}, "previous_state_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "target_identity_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "upstream_evidence_digests": {"type": "array", "items": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}}}}
  }
}
