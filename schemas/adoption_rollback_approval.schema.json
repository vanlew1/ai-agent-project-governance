{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://vanlew1.github.io/ai-agent-project-governance/schemas/adoption_rollback_approval.schema.json","title":"Adoption Rollback Approval","description":"Legacy approval record retained for compatibility; automatic deletion is unsupported and callers must use the read-only manual assessment.","type":"object","additionalProperties":false,"required":["schema_version","target_identity_digest","installation_receipt_digest","approved_by_user","approved_action"],"properties":{"schema_version":{"const":"1.0"},"target_identity_digest":{"type":"string","pattern":"^[a-f0-9]{64}$"},"installation_receipt_digest":{"type":"string","pattern":"^[a-f0-9]{64}$"},"approved_by_user":{"const":true},"approved_action":{"const":"ROLLBACK_CREATED_FILES_ONLY"}}}
