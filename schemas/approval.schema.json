{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vanlew1.github.io/ai-agent-project-governance/schemas/approval.schema.json",
  "title": "Governance Approval Record",
  "description": "A human approval record and its reuse invalidation conditions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "approval_id",
    "task_id",
    "approval_type",
    "status",
    "scope",
    "environment_fingerprint",
    "approved_by",
    "approved_at",
    "expires_when"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "approval_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "approval_type": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "pending",
        "approved",
        "rejected",
        "expired"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": true
    },
    "environment_fingerprint": {
      "type": "object",
      "additionalProperties": true
    },
    "approved_by": {
      "type": "string",
      "minLength": 1
    },
    "approved_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_when": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "expired_at": {
      "type": "string",
      "format": "date-time"
    },
    "contract_digest": {
      "type": "string"
    }
  }
}
