{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://vanlew1.github.io/ai-agent-project-governance/schemas/adoption_installation_receipt.schema.json","title":"Adoption Installation Receipt","description":"Sanitized receipt for a new-files-only unactivated Runtime-artifact installation.","type":"object","additionalProperties":false,"required":["schema_version","status","target_identity_digest","plan_digest","confirmation_digest","export_manifest_digest","final_approval_digest","runtime_artifact_manifest_digest","compiler","installed","activated","tests_executed","verification_completed","closure_completed","created_files","created_directories","file_hashes","blocked_decisions","automatic_rollback_available","rollback_assessment_available","rollback_mode"],"properties":{"schema_version":{"const":"1.0"},"status":{"enum":["INSTALLED_NOT_ACTIVATED","PARTIAL_INSTALL_REQUIRES_MANUAL_RECOVERY"]},"target_identity_digest":{"type":"string"},"plan_digest":{"type":"string"},"confirmation_digest":{"type":"string"},"export_manifest_digest":{"type":"string"},"final_approval_digest":{"type":"string"},"runtime_artifact_manifest_digest":{"type":"string","pattern":"^[a-f0-9]{64}$"},"compiler":{"type":"object","additionalProperties":false,"required":["id","version","digest"],"properties":{"id":{"type":"string"},"version":{"type":"string"},"digest":{"type":"string","pattern":"^[a-f0-9]{64}$"}}},"installed":{"type":"boolean"},"activated":{"const":false},"tests_executed":{"const":false},"verification_completed":{"const":false},"closure_completed":{"const":false},"created_files":{"type":"array","items":{"enum":["task.yaml","project_state.yaml"]}},"created_directories":{"type":"array","maxItems":0},"file_hashes":{"type":"object","additionalProperties":{"type":"string"}},"blocked_decisions":{"type":"array","items":{"type":"string"}},"automatic_rollback_available":{"const":false},"rollback_assessment_available":{"const":true},"rollback_mode":{"const":"MANUAL_ONLY"},"compile