{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vanlew1.github.io/ai-agent-project-governance/schemas/task_request.schema.json",
  "title": "Governance Task Request",
  "description": "A requested task before deterministic governance conclusions are computed.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task_id", "title", "description", "requested_by", "requested_at", "hints"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "task_id": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "requested_by": {"type": "string", "minLength": 1},
    "requested_at": {"type": "string", "format": "date-time"},
    "hints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["likely_paths", "external_access", "production_write"],
      "properties": {
        "likely_paths": {"type": "array", "items": {"type": "string"}},
        "external_access": {"type": "boolean"},
        "production_write": {"type": "boolean"}
      }
    }
  }
}
