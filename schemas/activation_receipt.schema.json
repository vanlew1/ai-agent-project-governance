{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://vanlew1.github.io/ai-agent-project-governance/schemas/activation_receipt.schema.json","title":"Adoption Activation Receipt","description":"Sanitized external receipt for a bounded approved Runtime activation.","type":"object","additionalProperties":false,"required":["schema_version","status","target_identity_digest","runtime_artifact_manifest_digest","final_install_approval_digest","installation_receipt_digest","activation_approval_digest","activation_receipt_binding_digest","compiler_id","compiler_version","compiler_digest","task_contract_digest","project_state_digest_before","project_state_digest_after","activated","preflight_executed","tests_executed","verification_completed","closure_completed"],"properties":{"schema_version":{"const":"1.0"},"status":{"enum":["PENDING_ACTIVATION","ACTIVATED_NOT_PREFLIGHTED","ACTIVATED_REQUIRES_MANUAL_REVIEW"]},"target_identity_digest":{"type":"string","pattern":"^[a-f0-9]{64}$"},"runtime_artifact_manifest_digest":{"type":"string","pattern":"^[a-f0-9]{64}$"},"final_install_approval_digest":{"type":"string","pattern":"^[a-f0-9]{64}$"},"installation_receipt_digest":{"type":"string","pattern":"^[a-f0-9]{64}$"},"activation_approval_digest":{"type":"string","pattern":"^[a-f0-9]{64}$"},"activation_receipt_binding_digest":{"type":"string","pattern":"^[a-f0-9]{64}$"},"compiler_id":{"type":"string"},"compiler_version":{"type":"string"},"compiler_digest":{"type":"string","pattern":"^[a-f0-9]{64}$"},"task_contract_digest":{"type":"string","pattern":"^[a-f0-9]{64}$"},"project_state_digest_before":{"type":"string","pattern":"^[a-f0-9]{64}$"},"project_state_digest_after":{"type":"string","pattern":"^[a-f0-9]{64}$"},"activated":{"type":"boolean"},"preflight_executed":{"const":false},"tests_executed":{"const":false},"verification_completed":{"const":false},"closure_completed":{"const":false}}}
