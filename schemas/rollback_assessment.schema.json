{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://vanlew1.github.io/ai-agent-project-governance/schemas/rollback_assessment.schema.json","title":"Read-only Rollback Assessment","description":"Point-in-time manual cleanup assessment that never deletes target files.","type":"object","additionalProperties":false,"required":["schema_version","status","target_identity_match","automatic_rollback_available","rollback_mode","candidates","conflicts","warnings"],"properties":{"schema_version":{"const":"1.0"},"status":{"const":"MANUAL_ROLLBACK_REVIEW_REQUIRED"},"target_identity_match":{"const":true},"automatic_rollback_available":{"const":false},"rollback_mode":{"const":"MANUAL_ONLY"},"candidates":{"type":"array","items":{"type":"object"}},"conflicts":{"type":"array","items":{"type":"object"}},"warnings":{"type":"array","minItems":2,"items":{"type":"string"}}}}
