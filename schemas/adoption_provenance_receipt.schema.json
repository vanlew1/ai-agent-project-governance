{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vanlew1.github.io/ai-agent-project-governance/schemas/adoption_provenance_receipt.schema.json",
  "title": "Adoption Toolchain Provenance Receipt",
  "description": "Digest binding to a public local toolchain invocation. Generator source digest v2 binds clean Git HEAD blobs rather than checkout bytes; it is not a keyed signature or cryptographic anti-forgery proof.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "binding_type", "generator_id", "generator_version", "generator_source_digest", "generator_source_basis", "generator_source_contract_version", "generation_path", "generation_command_contract_digest", "formal_scope_input_digest", "formal_scope_normalized_text_digest", "target_identity", "target_branch", "target_head", "framework_commit", "plan_payload_digest", "generated_at", "provenance_receipt_digest"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "binding_type": {"const": "TOOLCHAIN_PROVENANCE_BINDING"},
    "generator_id": {"const": "ai-agent-project-governance-planner"},
    "generator_version": {"type": "string", "minLength": 1},
    "generator_source_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "generator_source_basis": {"const": "git_head_blob"},
    "generator_source_contract_version": {"const": 2},
    "generation_path": {"type": "string", "minLength": 1},
    "generation_command_contract_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "formal_scope_input_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "formal_scope_normalized_text_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "target_identity": {"type": "object"},
    "target_branch": {"type": "string", "minLength": 1},
    "target_head": {"type": "string", "minLength": 1},
    "framework_commit": {"type": "string", "minLength": 1},
    "plan_payload_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "generated_at": {"type": "string", "minLength": 1},
    "provenance_receipt_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
