{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vanlew1.github.io/ai-agent-project-governance/schemas/adoption_final_approval.schema.json",
  "title": "Final Adoption Installation Approval",
  "description": "Explicit Owner approval binding exact scope, provenance, pre-write manifests, Runtime bytes, and compiler identity.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "target_identity_digest", "plan_digest", "confirmation_digest", "export_manifest_digest", "runtime_artifact_manifest_digest", "provenance_receipt_digest", "scope_contract", "scope_contract_digest", "writeset_digest", "pre_install_hashes_digest", "rollback_manifest_digest", "compiler", "runtime_artifacts", "approved_by_user", "install_approved", "activate_approved", "approved_action", "approved_files", "conflict_policy", "rollback_on_failure", "blocked_decisions"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "target_identity_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "plan_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "confirmation_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "export_manifest_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "runtime_artifact_manifest_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "provenance_receipt_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "scope_contract": {"type": "object"}, "scope_contract_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "writeset_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "pre_install_hashes_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "rollback_manifest_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "compiler": {"type": "object", "additionalProperties": false, "required": ["id", "version", "digest"], "properties": {"id": {"const": "governance.adoption.runtime_artifact_compiler"}, "version": {"type": "string", "minLength": 1}, "digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}},
    "runtime_artifacts": {"type": "object", "additionalProperties": false, "required": ["task_contract", "project_state"], "properties": {"task_contract": {"$ref": "#/$defs/artifact"}, "project_state": {"$ref": "#/$defs/artifact"}}},
    "approved_by_user": {"const": true}, "install_approved": {"const": true}, "activate_approved": {"const": false}, "approved_action": {"const": "INSTALL_NEW_FILES_ONLY"},
    "approved_files": {"type": "array", "minItems": 2, "maxItems": 2, "uniqueItems": true, "items": {"enum": ["task.yaml", "project_state.yaml"]}}, "conflict_policy": {"const": "FAIL_ON_EXISTING"}, "rollback_on_failure": {"const": true},
    "blocked_decisions": {"type": "object", "additionalProperties": false, "required": ["state_activation", "test_execution", "git_write", "network_access", "production_data", "external_api", "release", "security_bypass", "business_semantic_change"], "properties": {"state_activation": {"const": "BLOCKED"}, "test_execution": {"const": "BLOCKED"}, "git_write": {"const": "BLOCKED"}, "network_access": {"const": "BLOCKED"}, "production_data": {"const": "BLOCKED"}, "external_api": {"const": "BLOCKED"}, "release": {"const": "BLOCKED"}, "security_bypass": {"const": "BLOCKED"}, "business_semantic_change": {"const": "BLOCKED"}}}
  },
  "$defs": {"artifact": {"type": "object", "additionalProperties": false, "required": ["sha256"], "properties": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}}}
}
