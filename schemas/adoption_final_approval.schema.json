{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://vanlew1.github.io/ai-agent-project-governance/schemas/adoption_final_approval.schema.json","title":"Final Adoption Installation Approval","description":"Explicit approval binding exact precompiled Runtime bytes and compiler identity.","type":"object","additionalProperties":false,"required":["schema_version","target_identity_digest","plan_digest","confirmation_digest","export_manifest_digest","runtime_artifact_manifest_digest","compiler","runtime_artifacts","approved_by_user","approved_action","approved_files","conflict_policy","rollback_on_failure","blocked_decisions"],"properties":{"schema_version":{"const":"1.0"},"target_identity_digest":{"type":"string","pattern":"^[a-f0-9]{64}$"},"plan_digest":{"type":"string","pattern":"^[a-f0-9]{64}$"},"confirmation_digest":{"type":"string","pattern":"^[a-f0-9]{64}$"},"export_manifest_digest":{"type":"string","pattern":"^[a-f0-9]{64}$"},"runtime_artifact_manifest_digest":{"type":"string","pattern":"^[a-f0-9]{64}$"},"compiler":{"type":"object","additionalProperties":false,"required":["id","version","digest"],"properties":{"id":{"const":"governance.adoption.runtime_artifact_compiler"},"version":{"type":"string","minLength":1},"digest":{"type":"string","pattern":"^[a-f0-9]{64}$"}}},"runtime_artifacts":{"type":"object","additionalProperties":false,"required":["task_contract","project_state"],"properties":{"task_contract":{"type":"object","additionalProperties":false,"required":["sha256"],"properties":{"sha256":{"type":"string","pattern":"^[a-f0-9]{64}$"}}},"project_state":{"type":"object","additionalProperties":false,"required":["sha256"],"properties":{"sha256":{"type":"string","pattern":"^[a-f0-9]{64}$"}}}}},"approved_by_user":{"const":true},"approved_action":{"const":"INSTALL_NEW_FILES_ONLY"},"approved_files":{"type":"array","minItems":2,"maxItems":2,"uniqueItems":true,"items":{"enum":["task.yaml","project_state.yaml"]}},"conflict_policy":{"const":"FAIL_ON_