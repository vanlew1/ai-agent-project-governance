{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://vanlew1.github.io/ai-agent-project-governance/schemas/runtime_artifact_manifest.schema.json","title":"Runtime Artifact Preview Manifest","description":"Exact byte and compiler provenance for an external Runtime preview bundle.","type":"object","additionalProperties":false,"required":["schema_version","compiler_id","compiler_version","compiler_digest","plan_digest","confirmation_digest","export_manifest_digest","source_draft_digests","runtime_artifacts","manifest_digest"],"properties":{"schema_version":{"const":"1.0"},"compiler_id":{"const":"governance.adoption.runtime_artifact_compiler"},"compiler_version":{"type":"string","minLength":1},"compiler_digest":{"type":"string","pattern":"^[a-f0-9]{64}$"},"plan_digest":{"type":"string","pattern":"^[a-f0-9]{64}$"},"confirmation_digest":{"type":"string","pattern":"^[a-f0-9]{64}$"},"export_manifest_digest":{"type":"string","pattern":"^[a-f0-9]{64}$"},"source_draft_digests":{"type":"object","additionalProperties":false,"required":["task.yaml","project_state.yaml"],"properties":{"task.yaml":{"type":"string","pattern":"^[a-f0-9]{64}$"},"project_state.yaml":{"type":"string","pattern":"^[a-f0-9]{64}$"}}},"runtime_artifacts":{"type":"array","minItems":2,"maxItems":2,"uniqueItems":true,"items":{"type":"object","additionalProperties":false,"required":["artifact_type","relative_path","sha256","schema","loader"],"properties":{"artifact_type":{"enum":["TASK_CONTRACT","PROJECT_STATE"]},"relative_path":{"enum":["task_contract.runtime.yaml","project_state.runtime.yaml"]},"sha256":{"type":"string","pattern":"^[a-f0-9]{64}$"},"schema":{"enum":["task_contract.schema.json","project_state.schema.json"]},"loader":{"enum":["TaskContract.from_mapping","ProjectState.from_mapping"]}}}},"manifest_digest":{"type":"string","pattern":"^[a-f0-9]{64}$"}}}
